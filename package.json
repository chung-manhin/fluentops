{
  "name": "fluentops",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": "20"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": "4.5.4",
      "glob": "10.5.0",
      "minimatch@3.1.2": "3.1.4",
      "minimatch@3.1.3": "3.1.4",
      "minimatch@9.0.1": "9.0.7",
      "minimatch@9.0.5": "9.0.7",
      "minimatch@9.0.6": "9.0.7",
      "rollup": "4.59.0",
      "multer": "2.1.1",
      "flatted": "3.4.0",
      "serialize-javascript": "7.0.3",
      "undici": "7.24.0"
    }
  },
  "scripts": {
    "dev": "node ./scripts/run-turbo.mjs dev --parallel",
    "lint": "node ./scripts/run-turbo.mjs lint",
    "typecheck": "node ./scripts/run-turbo.mjs typecheck",
    "test": "node ./scripts/run-turbo.mjs test",
    "build": "node ./scripts/run-turbo.mjs build",
    "audit": "pnpm audit --audit-level=high",
    "format": "prettier . --check",
    "format:write": "prettier . --write"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^25.2.2",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "turbo": "^2.4.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.23.0",
    "vitest": "^2.1.9",
    "vue-eslint-parser": "^9.4.3"
  }
}
